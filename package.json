{
  "name": "localterm",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@homebridge/node-pty-prebuilt-multiarch",
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "electron": "^31.7.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "ws": "^8.19.0"
  },
  "scripts": {
    "dev": "concurrently -k -n renderer,desktop -c cyan,green \"pnpm --filter @localterm/renderer dev\" \"pnpm --filter @localterm/desktop dev\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "echo \"TODO: wire workspace lint\"",
    "test": "pnpm test:integration",
    "test:integration": "tsx --test tests/integration/*.test.ts",
    "test:e2e": "echo \"TODO: wire Electron E2E tests\"",
    "verify:quick": "pnpm typecheck && pnpm test:integration",
    "acceptance:auto": "pnpm verify:quick && pnpm --filter @localterm/renderer build && pnpm debug:sessions",
    "verify:ci": "echo \"TODO: CI full verification pipeline\"",
    "debug:sessions": "tsx scripts/debug-sessions.ts",
    "kill:orphans": "tsx scripts/kill-orphans.ts",
    "perf:stress": "tsx scripts/perf-session-stress.ts"
  },
  "dependencies": {
    "react-resizable-panels": "^4.7.0"
  }
}
